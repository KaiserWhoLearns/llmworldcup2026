# Copy this file to `.env` and fill in the keys for the providers you want to run.
# predict.py loads this automatically (via python-dotenv).

# Anthropic — Fable 5, Opus 4.8
ANTHROPIC_API_KEY=

# OpenAI — GPT models
OPENAI_API_KEY=

# Google — Gemini
GOOGLE_API_KEY=

# Together AI — open-source models (Qwen, DeepSeek). OpenAI-compatible API.
TOGETHER_API_KEY=
